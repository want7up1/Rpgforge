COMPOSE_PROJECT_NAME=rpgforge

# API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://rpg:rpg@postgres:5432/rpgforge
REDIS_URL=redis://redis:6379/0

# DeepSeek V4 defaults. These can also be configured from /settings.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
SETTINGS_ADMIN_TOKEN=change-this-token-before-exposing

# Xiaomi MiMo TTS. Leave empty until Phase 5 integration is enabled.
MIMO_API_KEY=
AUDIO_STORAGE_PATH=/data/audio

# Web
INTERNAL_API_URL=http://api:8000
